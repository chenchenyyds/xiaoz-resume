# ==================== 运行环境 ====================
APP_ENV=development                  # development / production
APP_DEBUG=true
APP_NAME=xiaoz-resume
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000    # 对外 base_url（用于支付回调拼接）
APP_FRONTEND_USER_URL=http://localhost:5173
APP_FRONTEND_ADMIN_URL=http://localhost:5174

# ==================== 数据库 ====================
DATABASE_URL=postgresql+psycopg2://xiaoz:xiaoz_pwd@localhost:5432/xiaoz_resume
# 本地 SQLite 调试用：DATABASE_URL=sqlite:///./xiaoz.db

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== JWT ====================
JWT_SECRET_KEY=please-change-me-in-production-32bytes-min
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 天

# ==================== 阿里云 OSS ====================
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET=xiaoz-resume-files
OSS_BASE_URL=https://xiaoz-resume-files.oss-cn-shanghai.aliyuncs.com

# ==================== 阿里云短信 ====================
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=小Z简历
SMS_TEMPLATE_CODE=SMS_xxxxxx
SMS_REGION=cn-hangzhou

# 开发模式：true 时验证码固定 123456，不真发短信
SMS_DEV_MODE=true

# ==================== 虎皮椒支付 ====================
HUPIIJIAO_API_URL=https://api.hupijiao.com/v1
HUPIIJIAO_MERCHANT_ID=your-merchant-id
HUPIIJIAO_MERCHANT_KEY=your-merchant-key
HUPIIJIAO_NOTIFY_URL=https://yourdomain.com/api/orders/hupijiao/notify
HUPIIJIAO_RETURN_URL=https://yourdomain.com/orders/result

# 沙箱模式：true 用虎皮椒沙箱地址
HUPIIJIAO_SANDBOX=true

# ==================== DeepSeek LLM ====================
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ==================== 管理员 ====================
# 首次启动时通过 python -m scripts.create_admin 创建
ADMIN_DEFAULT_PHONE=13800000000

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]
